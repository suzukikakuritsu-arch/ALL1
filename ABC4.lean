# =========================================================
# Spectral Numerical Realization (Suzuki OS)
# RH / GUE / β* empirical model
# =========================================================

import numpy as np

# ---------------------------------------------------------
# 1. 擬似ゼータ零点データ（実際は高精度計算から取得）
# ---------------------------------------------------------
# imaginary parts of zeta zeros (toy model)
zeros_imag = np.array([
    14.1347, 21.0220, 25.0108, 30.4249,
    32.9351, 37.5862, 40.9187, 43.3271
])

# ---------------------------------------------------------
# 2. スペクトル密度（GUE近似）
# ρ(t) ≈ (1/2π) log t
# ---------------------------------------------------------
def rho(t):
    return (1 / (2 * np.pi)) * np.log(t)

# ---------------------------------------------------------
# 3. 累積スペクトルエネルギー
# β(R) = ∫ ρ(t) dt
# ---------------------------------------------------------
def beta(R, n=10000):
    t = np.linspace(1, R, n)
    return np.trapz(rho(t), t)

# ---------------------------------------------------------
# 4. β*（極限近似）
# ---------------------------------------------------------
R_max = 1e5
beta_star = beta(R_max)

print("β* (spectral limit) ≈", beta_star)

# ---------------------------------------------------------
# 5. 零点間隔（GUE統計確認）
# ---------------------------------------------------------
gaps = np.diff(zeros_imag)
normalized_gaps = gaps / np.mean(gaps)

print("normalized gaps:", normalized_gaps)

# ---------------------------------------------------------
# 6. Wigner-Dyson分布との比較（簡易）
# ---------------------------------------------------------
def wigner_pdf(s):
    return (np.pi/2) * s * np.exp(-np.pi * s**2 / 4)

s = np.linspace(0, 3, 100)
pdf = wigner_pdf(s)

# ---------------------------------------------------------
# 7. RHチェック（実部固定仮定）
# ---------------------------------------------------------
def RH_check(real_parts):
    return np.allclose(real_parts, 0.5)

# 仮データ（RH仮定）
real_parts = np.full_like(zeros_imag, 0.5)

print("RH consistency:", RH_check(real_parts))

# ---------------------------------------------------------
# 8. スペクトル安定性チェック（β*境界）
# ---------------------------------------------------------
spectral_bound_check = np.all(zeros_imag <= beta_star)

print("spectral bound satisfied:", spectral_bound_check)
